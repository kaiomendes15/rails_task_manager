<div class="min-h-screen bg-slate-900 text-white p-6 md:p-12">
  
  <div class="mb-10 flex flex-col md:flex-row justify-between items-start md:items-end border-b border-slate-700 pb-6 gap-4">
    <div>
      <div class="flex items-center gap-3 mb-2">
        <svg class="w-8 h-8 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
        <h1 class="text-4xl font-bold text-white">Painel Administrativo</h1>
      </div>
      <p class="text-slate-400">Gerenciamento de usuários e controle de acesso ao sistema.</p>
    </div>

    <%= link_to new_admin_user_path, class: "flex items-center bg-red-600 hover:bg-red-700 text-white font-bold py-2 px-4 rounded-lg transition duration-200 shadow-lg shrink-0" do %>
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
      Novo Usuário
    <% end %>
  </div>

  <div class="bg-slate-800 rounded-xl border border-slate-700 overflow-x-auto shadow-xl">
    <table class="w-full text-left border-collapse min-w-[600px]">
      <thead>
        <tr class="bg-slate-900/50 border-b border-slate-700 text-slate-400 text-sm uppercase tracking-wider">
          <th class="p-4 font-semibold pl-6">Usuário</th>
          <th class="p-4 font-semibold">Papel</th>
          <th class="p-4 font-semibold">Criado em</th>
          <th class="p-4 font-semibold text-right pr-6">Ações</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-700/50">
        
        <% @users.each do |user| %>
          <tr class="hover:bg-slate-700/20 transition duration-150">
            
            <td class="p-4 pl-6 font-medium text-slate-200">
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-full bg-slate-700 border border-slate-600 flex items-center justify-center text-sm font-bold text-slate-300">
                  <%= user.email[0].upcase %>
                </div>
                <%= user.email %>
              </div>
            </td>
            
            <td class="p-4">
              <% if user.is_admin? %>
                <span class="bg-blue-900/40 text-blue-400 border border-blue-800/50 px-2.5 py-1 rounded text-[10px] font-bold uppercase tracking-wider">
                  Admin
                </span>
              <% else %>
                <span class="bg-slate-700/50 text-slate-400 border border-slate-600/50 px-2.5 py-1 rounded text-[10px] font-bold uppercase tracking-wider">
                  Usuário Padrão
                </span>
              <% end %>
            </td>
            
            <td class="p-4 text-slate-400 text-sm">
              <%= user.created_at.strftime("%d/%m/%Y") %>
            </td>
            
            <td class="p-4 pr-6">
              <div class="flex justify-end gap-3 items-center">
                
                <%= link_to edit_admin_user_path(user), class: "text-slate-500 hover:text-blue-400 transition duration-200", title: "Editar Usuário" do %>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                <% end %>
                
                <% if user == current_user %>
                  <span class="text-slate-700 cursor-not-allowed" title="Você não pode excluir a própria conta">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                  </span>
                <% else %>
                  <%= button_to admin_user_path(user), method: :delete, form: { class: "inline-flex", data: { turbo_confirm: "Excluir este usuário apagará permanentemente TODAS as categorias e tarefas pertencentes a ele. Tem certeza absoluta?" } }, class: "text-slate-500 hover:text-red-500 transition duration-200 bg-transparent border-none cursor-pointer", title: "Excluir Usuário" do %>
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                  <% end %>
                <% end %>
                
              </div>
            </td>
            
          </tr>
        <% end %>
        
      </tbody>
    </table>
  </div>

  <div class="mt-8 text-center md:text-left">
    <%= link_to root_path, class: "inline-flex items-center text-sm font-medium text-slate-400 hover:text-white transition duration-200" do %>
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
      Voltar para o Dashboard
    <% end %>
  </div>

</div>