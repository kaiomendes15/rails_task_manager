<%= form_with(model: task, class: "w-full") do |form| %>

  <div class="mb-6">
    <%= form.label :title, "Título da Tarefa", class: "block text-slate-400 text-sm font-bold mb-2" %>
    <%= form.text_field :title, class: "w-full bg-slate-700 border #{task.errors[:title].any? ? 'border-red-500' : 'border-slate-600'} text-white rounded-lg px-4 py-3 focus:outline-none focus:border-red-500 focus:ring-1 focus:ring-red-500 transition duration-200" %>
    <% if task.errors[:title].any? %>
      <p class="text-red-500 text-xs italic mt-2"><%= task.errors.full_messages_for(:title).first %></p>
    <% end %>
  </div>

  <div class="mb-6">
    <%= form.label :due_date, "Data de Vencimento", class: "block text-slate-400 text-sm font-bold mb-2" %>
    <%= form.datetime_field :due_date, class: "w-full bg-slate-700 border #{task.errors[:due_date].any? ? 'border-red-500' : 'border-slate-600'} text-white rounded-lg px-4 py-3 focus:outline-none focus:border-red-500 focus:ring-1 focus:ring-red-500 transition duration-200 [color-scheme:dark]" %>
    <% if task.errors[:due_date].any? %>
      <p class="text-red-500 text-xs italic mt-2"><%= task.errors.full_messages_for(:due_date).first %></p>
    <% end %>
  </div>

  <div class="mb-6">
    <%= form.label :category_id, "Categoria", class: "block text-slate-400 text-sm font-bold mb-2" %>
    <%= form.collection_select(:category_id, current_user.categories, :id, :title, { prompt: "Selecione..." }, { class: "w-full bg-slate-700 border #{task.errors[:category_id].any? ? 'border-red-500' : 'border-slate-600'} text-white rounded-lg px-4 py-3 focus:outline-none focus:border-red-500 focus:ring-1 focus:ring-red-500 transition duration-200" }) %>
    <% if task.errors[:category_id].any? %>
      <p class="text-red-500 text-xs italic mt-2"><%= task.errors.full_messages_for(:category_id).first %></p>
    <% end %>
  </div>

  <div class="mt-8 flex gap-4">
    <%= link_to "Cancelar", root_path, class: "w-1/3 text-center bg-slate-700 hover:bg-slate-600 text-white font-bold py-3 rounded-lg transition duration-200" %>
    <%= form.submit "Salvar", class: "w-2/3 bg-red-600 hover:bg-red-700 text-white font-bold rounded-lg py-3 transition duration-200 cursor-pointer" %>
  </div>
<% end %>