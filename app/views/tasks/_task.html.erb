<div id="<%= dom_id task %>">
  <div>
    <strong>Title:</strong>
    <%= task.title %>
  </div>

  <div>
    <strong>Status:</strong>
    <%= task.status %>
  </div>

  <div>
    <strong>Due date:</strong>
    <%= task.due_date %>
  </div>

  <div>
    <strong>Category:</strong>
    <%= task.category_id %>
  </div>

  <div>
    <strong>User:</strong>
    <%= task.user_id %>
  </div>

</div>
