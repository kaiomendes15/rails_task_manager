<div class="min-h-screen bg-slate-900 text-white p-6 md:p-12">
  
  <div class="mb-12 flex justify-between items-end border-b border-slate-700 pb-6">
    <div>
      <h1 class="text-4xl font-bold text-white mb-2">Meu Dashboard</h1>
      <p class="text-slate-400">Bem-vindo(a), <%= current_user.email %></p>
    </div>
  </div>

  <div class="mb-8 flex gap-4">
    <%= link_to new_category_path, class: "flex items-center bg-slate-800 hover:bg-slate-700 border border-slate-600 text-white font-bold py-2 px-4 rounded-lg transition duration-200 shadow-lg" do %>
      <svg class="w-5 h-5 mr-2 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
      Nova Categoria
    <% end %>

    <%= link_to new_task_path, class: "flex items-center bg-red-600 hover:bg-red-700 text-white font-bold py-2 px-4 rounded-lg transition duration-200 shadow-lg" do %>
      <svg class="w-5 h-5 mr-2 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
      Nova Tarefa
    <% end %>
  </div>

  <% if @categories.empty? %>
    <div class="text-center bg-slate-800 rounded-xl p-10 border border-slate-700">
      <p class="text-slate-400">Você ainda não possui categorias criadas.</p>
    </div>
  <% else %>
    
    <% @categories.each do |category| %>
      <div class="mb-14">
        
        <div class="border-b border-slate-700 pb-3 mb-6 flex justify-between items-end">
          
          <h2 class="text-2xl font-bold text-slate-100 flex items-center flex-wrap gap-3">
            <span class="bg-slate-800 border border-slate-600 px-3 py-1 rounded-md text-sm text-slate-400 font-normal">
              Categoria
            </span>
            <%= category.title %>
            
            <% if current_user.is_admin? %>
              <span class="bg-blue-900/30 text-blue-400 border border-blue-800/50 px-2 py-1 rounded text-xs font-normal flex items-center gap-1 mt-1 sm:mt-0">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                <%= category.user.email %>
              </span>
            <% end %>
          </h2>
          
          <div class="flex items-center gap-3">
            <%= link_to edit_category_path(category), class: "text-slate-500 hover:text-blue-400 transition duration-200", title: "Editar Categoria" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
            <% end %>
            
            <%= button_to category, method: :delete, form: { class: "inline-flex", data: { turbo_confirm: "Excluir esta categoria apagará TODAS as tarefas dentro dela. Tem certeza?" } }, class: "text-slate-500 hover:text-red-500 transition duration-200 bg-transparent border-none cursor-pointer", title: "Excluir Categoria" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
            <% end %>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          
          <% if category.tasks.empty? %>
            <p class="text-slate-500 italic text-sm">Nenhuma tarefa cadastrada nesta categoria.</p>
          <% else %>
            
            <% category.tasks.each do |task| %>
              <div class="bg-slate-800 rounded-xl p-6 border border-slate-700 shadow-lg hover:border-slate-500 transition duration-200 flex flex-col justify-between">
                
                <div>
                  <div class="flex justify-between items-start mb-2 gap-2">
                    <h3 class="text-lg font-bold text-white leading-tight"><%= task.title %></h3>
                    
                    <% 
                      status_classes = case task.status
                                      when 'pendente'
                                          'bg-red-500/10 text-red-500 border-red-500/50 hover:bg-red-500/20'
                                      when 'em_progresso'
                                          'bg-yellow-500/10 text-yellow-500 border-yellow-500/50 hover:bg-yellow-500/20'
                                      when 'concluida'
                                          'bg-emerald-500/10 text-emerald-500 border-emerald-500/50 hover:bg-emerald-500/20'
                                      else
                                          'bg-slate-500/10 text-slate-500 border-slate-500/50 hover:bg-slate-500/20'
                                      end
                      %>

                    <%= form_with(model: task, class: "shrink-0 relative inline-block") do |f| %>
                      <%= f.select :status, 
                                  Task.statuses.keys.map { |status| [status.titleize, status, { class: "bg-slate-800 text-slate-200 font-sans tracking-normal capitalize" }] }, 
                                  {}, 
                                  { 
                                      class: "appearance-none text-[10px] uppercase tracking-wider font-bold px-3 py-1.5 pr-7 rounded border #{status_classes} cursor-pointer focus:outline-none focus:ring-1 focus:ring-slate-400 transition duration-200", 
                                      onchange: "this.form.requestSubmit();" 
                                  } 
                      %>
                      
                      <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-current opacity-70">
                          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                      </div>
                    <% end %>
                  </div>

                  <% if current_user.is_admin? %>
                    <div class="text-[11px] text-blue-400/80 mb-4 flex items-center gap-1 font-medium">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                      <%= task.user.email %>
                    </div>
                  <% else %>
                    <div class="mb-4"></div>
                  <% end %>
                </div>
                
                <div class="flex justify-between items-center mt-auto pt-4 border-t border-slate-700/50">
                  <div class="text-sm text-slate-400 flex items-center">
                    <svg class="w-4 h-4 mr-2 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    <%= task.due_date ? task.due_date.strftime("%d/%m/%Y") : "Sem data" %>
                  </div>
                  
                  <div class="flex gap-2">
                    <%= link_to edit_task_path(task), class: "text-slate-500 hover:text-blue-400 transition duration-200", title: "Editar Tarefa" do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.5h18.536z"></path></svg>
                    <% end %>
                    
                    <%= button_to task, method: :delete, form: { class: "inline-flex", data: { turbo_confirm: "Excluir esta tarefa?" } }, class: "text-slate-500 hover:text-red-500 transition duration-200 bg-transparent border-none cursor-pointer", title: "Excluir Tarefa" do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                    <% end %>
                  </div>
                </div>

              </div>
            <% end %>
            
          <% end %>
        </div>

      </div>
    <% end %>
    
  <% end %>

</div>